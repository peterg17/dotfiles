[url "git@github.com:"]
	insteadOf = https://github.com/
	insteadOf = git://github.com/

[user]
  name = Peter Griggs
  email = petergriggs17@gmail.com
[core]
	editor = nvr -cc split --remote-wait +'set bufhidden=delete'

[alias]
  lg = log --graph --oneline --all --decorate

[include]
  path = ~/.gitconfig.local
