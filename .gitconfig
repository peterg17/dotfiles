[url "git@github.com:"]
	insteadOf = https://github.com/
	insteadOf = git://github.com/

[user]
  name = Peter Griggs
  email = petergriggs17@gmail.com
	signingkey = ~/.ssh/id_ed25519_signing.pub
[core]
	editor = nvr -cc 'if !empty(bufname("%")) || line("$") > 1 || !empty(getline(1)) | tabnew | endif' --remote-wait +'set bufhidden=delete'

[alias]
  lg = log --graph --oneline --all --decorate

[gpg]
	format = ssh
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers

# Keep this last so machine-specific overrides (e.g. dotfiles-dd) win.
# Missing-include is silently ignored by git, so this is safe on machines
# (e.g. personal laptop) where the override file doesn't exist.
[include]
	path = ~/.gitconfig-datadog
